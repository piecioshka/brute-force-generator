{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationDir": "types"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.spec.ts", "node_modules", "dist", "types"]
}
